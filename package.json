{
  "name": "tfb-skybridge",
  "version": "0.1.3",
  "description": "Proof-carrying admission for third-party agent apps. The dev CLI: run the discriminator on your own code; verdict in milliseconds with the exact seed × payload × call site that caused any catch.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Saul Lowery",
    "email": "saul@projecttfb.com",
    "url": "https://www.projecttfb.com/skybridge/"
  },
  "homepage": "https://www.projecttfb.com/skybridge/",
  "keywords": [
    "agent",
    "admission-control",
    "csp",
    "content-security-policy",
    "pre-ship",
    "sandbox",
    "transparency-log",
    "merkle",
    "supply-chain",
    "app-store",
    "cli",
    "tfb",
    "skybridge"
  ],
  "bin": {
    "tfb-skybridge": "dist/bin/skybridge-cli.js",
    "skybridge": "dist/bin/skybridge-cli.js"
  },
  "files": [
    "dist/",
    "src/",
    "bin/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx test/harness.ts",
    "demo": "tsx demo.ts",
    "poc": "tsx poc/server.ts",
    "check": "tsx bin/skybridge-cli.ts check",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/postbuild.mjs && chmod +x dist/bin/skybridge-cli.js",
    "verify:consumer-install": "node scripts/verify-consumer-install.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run verify:consumer-install"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
